{
  "name": "AWS WAF — Administrative Surface Allowlist",
  "vendor": "aws-waf",
  "category": "access_control",
  "app_context": "admin_panel",
  "objective": "Restrict common administrative routes to trusted source ranges by enforcing an IP set allowlist for sensitive panels and operational consoles.",
  "risk_mitigated": "Administrative surface reconnaissance and unauthorized access attempts against control panels, back-office paths, and operational interfaces.",
  "severity": "high",
  "mode": "block",
  "recommended_for": ["admin_panels", "web_apps", "apis"],
  "potential_side_effects": "Administrators using dynamic residential IPs, emergency break-glass workflows, or third-party managed support tools can be blocked if their addresses are not explicitly captured.",
  "tuning_notes": "Back the rule with a maintained IP set and document emergency procedures for temporarily expanding the allowlist. Keep test and break-glass paths separate from primary production panels when possible.",
  "deployment_notes": "Deploy after building the trusted IP set for VPN, office, bastion, and support ranges. Start in Count mode only if you are still validating operational dependencies.",
  "monitoring_notes": "Alert on repeated blocks to /admin, /wp-admin, /backoffice, and /internal-admin paths from unknown ASNs or geographies. Review sampled requests weekly to validate the allowlist remains accurate.",
  "version": "1.0.0",
  "maturity": "reviewed",
  "references": [
    "https://docs.aws.amazon.com/waf/latest/developerguide/waf-rule-statement-type-ipset-match.html",
    "https://cheatsheetseries.owasp.org/cheatsheets/Administrative_Interfaces_Cheat_Sheet.html"
  ],
  "aws_waf_rule": {
    "Name": "ProtectAdminSurfaceAllowlist",
    "Priority": 3,
    "Action": {
      "Block": {}
    },
    "VisibilityConfig": {
      "SampledRequestsEnabled": true,
      "CloudWatchMetricsEnabled": true,
      "MetricName": "ProtectAdminSurfaceAllowlist"
    },
    "Statement": {
      "AndStatement": {
        "Statements": [
          {
            "OrStatement": {
              "Statements": [
                {
                  "ByteMatchStatement": {
                    "SearchString": "/admin",
                    "FieldToMatch": {
                      "UriPath": {}
                    },
                    "TextTransformations": [
                      {
                        "Priority": 0,
                        "Type": "LOWERCASE"
                      }
                    ],
                    "PositionalConstraint": "STARTS_WITH"
                  }
                },
                {
                  "ByteMatchStatement": {
                    "SearchString": "/wp-admin",
                    "FieldToMatch": {
                      "UriPath": {}
                    },
                    "TextTransformations": [
                      {
                        "Priority": 0,
                        "Type": "LOWERCASE"
                      }
                    ],
                    "PositionalConstraint": "STARTS_WITH"
                  }
                },
                {
                  "ByteMatchStatement": {
                    "SearchString": "/backoffice",
                    "FieldToMatch": {
                      "UriPath": {}
                    },
                    "TextTransformations": [
                      {
                        "Priority": 0,
                        "Type": "LOWERCASE"
                      }
                    ],
                    "PositionalConstraint": "STARTS_WITH"
                  }
                }
              ]
            }
          },
          {
            "NotStatement": {
              "Statement": {
                "IPSetReferenceStatement": {
                  "ARN": "REPLACE_WITH_ADMIN_IP_SET_ARN"
                }
              }
            }
          }
        ]
      }
    }
  },
  "tags": ["aws-waf", "admin-surface", "allowlist", "access-control", "high"]
}
