{
  "name": "AWS WAF — Password Reset Flow Rate Limit",
  "vendor": "aws-waf",
  "category": "authentication_protection",
  "app_context": "generic",
  "objective": "Limit password reset and account recovery requests per source IP to reduce recovery-flow abuse and mailbox flooding.",
  "risk_mitigated": "Password reset abuse, account enumeration through recovery paths, and high-volume recovery-triggered account takeover attempts.",
  "severity": "high",
  "mode": "count",
  "recommended_for": ["web_apps", "apis", "admin_panels"],
  "potential_side_effects": "Large shared networks, support-led onboarding, and legitimate user retries can create short bursts on recovery endpoints.",
  "tuning_notes": "Begin in Count mode with a limit between 20 and 50 requests per IP over 10 minutes depending on your user base. Tighten only after reviewing sampled requests and helpdesk patterns.",
  "deployment_notes": "Apply to POST recovery endpoints before the managed authentication rule groups so recovery abuse is measured separately from generic bad-input detections.",
  "monitoring_notes": "Correlate rate-limit matches with downstream identity telemetry such as failed MFA resets, unusual mailbox traffic, and repeated recovery requests for the same account.",
  "version": "1.0.0",
  "maturity": "reviewed",
  "references": [
    "https://cheatsheetseries.owasp.org/cheatsheets/Forgot_Password_Cheat_Sheet.html",
    "https://docs.aws.amazon.com/waf/latest/developerguide/waf-rule-statement-type-rate-based.html"
  ],
  "aws_waf_rule": {
    "Name": "PasswordResetRateLimit",
    "Priority": 4,
    "Action": {
      "Count": {}
    },
    "VisibilityConfig": {
      "SampledRequestsEnabled": true,
      "CloudWatchMetricsEnabled": true,
      "MetricName": "PasswordResetRateLimit"
    },
    "Statement": {
      "RateBasedStatement": {
        "Limit": 30,
        "EvaluationWindowSec": 600,
        "AggregateKeyType": "IP",
        "ScopeDownStatement": {
          "AndStatement": {
            "Statements": [
              {
                "ByteMatchStatement": {
                  "SearchString": "POST",
                  "FieldToMatch": {
                    "Method": {}
                  },
                  "TextTransformations": [
                    {
                      "Priority": 0,
                      "Type": "NONE"
                    }
                  ],
                  "PositionalConstraint": "EXACTLY"
                }
              },
              {
                "OrStatement": {
                  "Statements": [
                    {
                      "ByteMatchStatement": {
                        "SearchString": "/forgot-password",
                        "FieldToMatch": {
                          "UriPath": {}
                        },
                        "TextTransformations": [
                          {
                            "Priority": 0,
                            "Type": "LOWERCASE"
                          }
                        ],
                        "PositionalConstraint": "CONTAINS"
                      }
                    },
                    {
                      "ByteMatchStatement": {
                        "SearchString": "/reset-password",
                        "FieldToMatch": {
                          "UriPath": {}
                        },
                        "TextTransformations": [
                          {
                            "Priority": 0,
                            "Type": "LOWERCASE"
                          }
                        ],
                        "PositionalConstraint": "CONTAINS"
                      }
                    },
                    {
                      "ByteMatchStatement": {
                        "SearchString": "/password/reset",
                        "FieldToMatch": {
                          "UriPath": {}
                        },
                        "TextTransformations": [
                          {
                            "Priority": 0,
                            "Type": "LOWERCASE"
                          }
                        ],
                        "PositionalConstraint": "CONTAINS"
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      }
    }
  },
  "tags": ["aws-waf", "password-reset", "authentication", "rate-limit", "high"]
}
